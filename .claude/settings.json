{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(node .claude/scripts/project/project-state.mjs:*)",
      "Bash(node .claude/scripts/project/show-folder.mjs:*)",
      "Bash(node .claude/scripts/image-edit/generate-edit.mjs:*)",
      "Bash(node .claude/scripts/world/generate-world.mjs:*)",
      "Bash(node .claude/scripts/asset-pipeline/generate-single-asset.mjs:*)",
      "Bash(node .claude/scripts/sfx/fal-elevenlabs-sfx.mjs:*)",
      "Bash(node .claude/scripts/fal/run-fal.mjs:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-check.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/input-check.sh"
          }
        ]
      }
    ]
  }
}
